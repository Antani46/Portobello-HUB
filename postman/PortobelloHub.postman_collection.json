{
  "info": {
    "name": "Portobello Hub API",
    "description": "Collection completa per testare tutte le rotte di Portobello Hub",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "itemId", "value": "1" },
    { "key": "categoryId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "reviewId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"mario_rossi\",\n  \"email\": \"mario.rossi@example.com\",\n  \"password\": \"Password123!\",\n  \"firstName\": \"Mario\",\n  \"lastName\": \"Rossi\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('userId', json.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@PortobelloHub.com\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  pm.collectionVariables.set('userId', json.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"mario.rossi@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+39 333 1234567\",\n  \"address\": \"Via Roma 10\",\n  \"city\": \"Milano\",\n  \"postalCode\": \"20100\"\n}"
            },
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Upload Avatar",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": "{{baseUrl}}/api/users/me/avatar"
          }
        },
        {
          "name": "Get Public Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/users/{{userId}}"
          }
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/users?page=0&size=20"
          }
        },
        {
          "name": "Assign Roles (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roles\": [\"ROLE_CUSTOMER\", \"ROLE_STAFF\"]\n}"
            },
            "url": "{{baseUrl}}/api/users/{{userId}}/roles"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories?page=0&size=20"
          }
        },
        {
          "name": "Get Category By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        },
        {
          "name": "Create Category (Staff)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tablet\",\n  \"description\": \"Tablet usati\",\n  \"slug\": \"tablet\",\n  \"itemType\": \"ELECTRONIC\"\n}"
            },
            "url": "{{baseUrl}}/api/categories"
          }
        },
        {
          "name": "Update Category (Staff)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Tablet ricondizionati\"\n}"
            },
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        },
        {
          "name": "Delete Category (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Items",
      "item": [
        {
          "name": "Search Published Items",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/items?page=0&size=20"
          }
        },
        {
          "name": "Get Item By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/items/{{itemId}}"
          }
        },
        {
          "name": "Get Item Price In Currency",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/items/{{itemId}}/price?currency=USD"
          }
        },
        {
          "name": "Get My Items",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/items/my?page=0&size=20"
          }
        },
        {
          "name": "Get Pending Items (Staff)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/items/pending?page=0&size=20"
          }
        },
        {
          "name": "Create Electronic Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('itemId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 13 128GB\",\n  \"description\": \"Ottime condizioni, batteria 87%\",\n  \"price\": 450.00,\n  \"condition\": \"GOOD\",\n  \"categoryId\": 1,\n  \"brand\": \"Apple\",\n  \"model\": \"iPhone 13\",\n  \"warrantyMonths\": 3,\n  \"batteryHealth\": 87\n}"
            },
            "url": "{{baseUrl}}/api/items/electronics"
          }
        },
        {
          "name": "Create Clothing Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Giacca Levi's Denim\",\n  \"description\": \"Taglia M, usata poco\",\n  \"price\": 45.00,\n  \"condition\": \"LIKE_NEW\",\n  \"categoryId\": 3,\n  \"size\": \"M\",\n  \"material\": \"Denim\",\n  \"gender\": \"UNISEX\"\n}"
            },
            "url": "{{baseUrl}}/api/items/clothing"
          }
        },
        {
          "name": "Update Electronic Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 420.00,\n  \"batteryHealth\": 85\n}"
            },
            "url": "{{baseUrl}}/api/items/electronics/{{itemId}}"
          }
        },
        {
          "name": "Upload Item Image",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": "{{baseUrl}}/api/items/{{itemId}}/image"
          }
        },
        {
          "name": "Approve Item (Staff)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"PUBLISHED\"\n}"
            },
            "url": "{{baseUrl}}/api/items/{{itemId}}/review"
          }
        },
        {
          "name": "Reject Item (Staff)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"REJECTED\",\n  \"rejectionReason\": \"Foto non sufficienti\"\n}"
            },
            "url": "{{baseUrl}}/api/items/{{itemId}}/review"
          }
        },
        {
          "name": "Delete Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/items/{{itemId}}"
          }
        }
      ]
    },
    {
      "name": "Currency",
      "item": [
        {
          "name": "Convert Currency",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/currency/convert?amount=100&from=EUR&to=USD"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('orderId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemIds\": [1],\n  \"notes\": \"Consegna dopo le 18\"\n}"
            },
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/orders/me?page=0&size=20"
          }
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          }
        },
        {
          "name": "List All Orders (Staff)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/orders?page=0&size=20"
          }
        },
        {
          "name": "Update Order Status (Staff)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            },
            "url": "{{baseUrl}}/api/orders/{{orderId}}/status"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get Item Reviews",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/items/{{itemId}}/reviews?page=0&size=20"
          }
        },
        {
          "name": "Create Review",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('reviewId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Articolo conforme alla descrizione\"\n}"
            },
            "url": "{{baseUrl}}/api/items/{{itemId}}/reviews"
          }
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"comment\": \"Buon prodotto, consegna rapida\"\n}"
            },
            "url": "{{baseUrl}}/api/reviews/{{reviewId}}"
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/reviews/{{reviewId}}"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Stats (REST)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/admin/stats"
          }
        }
      ]
    },
    {
      "name": "GraphQL",
      "item": [
        {
          "name": "Admin Stats Query",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query { adminStats { totalUsers publishedItems pendingItems totalOrders deliveredOrders totalRevenue inventoryByType { type count } } topSellingItems(limit: 5) { id name price salesCount } }\"\n}"
            },
            "url": "{{baseUrl}}/graphql"
          }
        }
      ]
    }
  ]
}
