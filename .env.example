# Copia questo file in .env e compila i valori reali.
# NON committare il file .env nel repository.

# Server
SERVER_PORT=8080

# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/portobello_hub
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# JPA
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# JWT (usa una chiave lunga almeno 256 bit in produzione)
JWT_SECRET=your-super-secret-jwt-key-minimum-256-bits-long!!
JWT_EXPIRATION_MS=86400000

# Cloudinary (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ExchangeRate-API (https://www.exchangerate-api.com)
EXCHANGE_RATE_BASE_URL=https://api.exchangerate-api.com/v4/latest/
EXCHANGE_RATE_API_KEY=
APP_BASE_CURRENCY=EUR

# Upload
MAX_FILE_SIZE=5MB
MAX_REQUEST_SIZE=10MB

# GraphQL
GRAPHQL_GRAPHIQL_ENABLED=true

# Seed admin (sviluppo)
SEED_ADMIN_EMAIL=admin@portobellohub.com
SEED_ADMIN_PASSWORD=Admin123!

# Logging
APP_LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN
